{
  "name": "artistico",
  "version": "0.1.0",
  "private": true,
  "description": "Low-fee marketplace for hobby creators",
  "scripts": {
    "dev": "pnpm --filter @artistico/web dev",
    "build": "pnpm --filter @artistico/web build",
    "start": "pnpm --filter @artistico/web start",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "dev:functions": "pnpm --filter @artistico/functions build:watch",
    "emulators": "firebase emulators:start --import=./firebase/.emulator-data --export-on-exit",
    "sync:functions": "node -e \"const{cpSync}=require('fs');cpSync('functions/src','functions-deploy/src',{recursive:true});cpSync('shared/src','functions-deploy/shared/src',{recursive:true});console.log('Synced functions/ → functions-deploy/')\"",
    "predeploy:staging": "pnpm sync:functions && pnpm --filter @artistico/shared build && pnpm --filter functions-deploy run build",
    "predeploy:production": "pnpm sync:functions && pnpm --filter @artistico/shared build && pnpm --filter functions-deploy run build",
    "deploy:staging": "pnpm predeploy:staging && firebase deploy --project staging",
    "deploy:production": "pnpm predeploy:production && firebase deploy --project production",
    "test:visual": "pnpm --filter @artistico/web test:visual",
    "test:report": "pnpm --filter @artistico/web test:report"
  },
  "keywords": [
    "marketplace",
    "hobby",
    "creators"
  ],
  "author": "",
  "license": "UNLICENSED",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["ffmpeg-static"]
  }
}
