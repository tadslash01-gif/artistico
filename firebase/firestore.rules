rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper functions ────────────────────────────────
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    function isCreator() {
      return isAuthenticated()
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isCreator == true;
    }

    // ─── Users ───────────────────────────────────────────
    match /users/{uid} {
      // Anyone can read public profiles
      allow read: if true;
      // Users can only write their own document
      allow create: if isOwner(uid);
      // Users can update their own doc, but cannot self-promote to creator
      // (isCreator is set only by Cloud Functions via admin SDK)
      allow update: if isOwner(uid)
                    && (!('isCreator' in request.resource.data) || request.resource.data.isCreator == resource.data.isCreator);
      // No deletes
      allow delete: if false;
    }

    // ─── Projects ────────────────────────────────────────
    match /projects/{projectId} {
      // Anyone can read published projects
      allow read: if resource.data.status == 'published'
                  || isOwner(resource.data.creatorId);
      // Only creators can create projects
      allow create: if isCreator()
                    && request.resource.data.creatorId == request.auth.uid;
      // Only the owning creator can update; creatorId is immutable
      allow update: if isOwner(resource.data.creatorId)
                    && request.resource.data.creatorId == resource.data.creatorId;
      // Soft delete only (status change) — no hard deletes
      allow delete: if false;
    }

    // ─── Products ────────────────────────────────────────
    match /products/{productId} {
      // Anyone can read active products
      allow read: if resource.data.status == 'active'
                  || isOwner(resource.data.creatorId);
      // Only the project's creator can create products
      allow create: if isCreator()
                    && request.resource.data.creatorId == request.auth.uid;
      // Only the owning creator can update; creatorId is immutable
      allow update: if isOwner(resource.data.creatorId)
                    && request.resource.data.creatorId == resource.data.creatorId;
      allow delete: if false;
    }

    // ─── Orders ──────────────────────────────────────────
    // Orders are created by Cloud Functions (admin SDK) only.
    // Users can read their own orders.
    match /orders/{orderId} {
      allow read: if isOwner(resource.data.buyerId)
                  || isOwner(resource.data.creatorId);
      allow create, update, delete: if false;
    }

    // ─── Reviews ─────────────────────────────────────────
    match /reviews/{reviewId} {
      // Anyone can read reviews
      allow read: if true;
      // Only buyers with a verified order can create
      allow create: if isAuthenticated()
                    && request.resource.data.buyerId == request.auth.uid
                    && request.resource.data.rating >= 1
                    && request.resource.data.rating <= 5
                    && exists(/databases/$(database)/documents/orders/$(request.resource.data.orderId))
                    && get(/databases/$(database)/documents/orders/$(request.resource.data.orderId)).data.buyerId == request.auth.uid
                    && get(/databases/$(database)/documents/orders/$(request.resource.data.orderId)).data.productId == request.resource.data.productId;
      // No updates or deletes (handled by admin if needed)
      allow update, delete: if false;
    }

    // ─── Saves ───────────────────────────────────────────
    match /saves/{saveId} {
      allow read: if isAuthenticated()
                  && request.auth.uid == resource.data.userId;
      allow create: if isAuthenticated()
                    && request.resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated()
                    && request.auth.uid == resource.data.userId;
      allow update: if false;
    }

    // ─── Follows ─────────────────────────────────────────
    match /follows/{followId} {
      allow read: if true;
      allow create: if isAuthenticated()
                    && request.resource.data.followerId == request.auth.uid
                    && request.resource.data.followerId != request.resource.data.followingId;
      allow delete: if isAuthenticated()
                    && request.auth.uid == resource.data.followerId;
      allow update: if false;
    }

    // ─── Recent Views (user subcollection) ───────────────
    match /users/{uid}/recentViews/{viewId} {
      allow read: if isOwner(uid);
      allow create, update: if isOwner(uid);
      allow delete: if isOwner(uid);
    }

    // ─── Reports ──────────────────────────────────────────────
    match /reports/{reportId} {
      // Reports are not publicly readable
      allow read: if isAuthenticated()
                  && request.auth.uid == resource.data.reporterId;
      // Authenticated users can create reports
      allow create: if isAuthenticated()
                    && request.resource.data.reporterId == request.auth.uid
                    && request.resource.data.status == 'pending';
      allow update, delete: if false;
    }

    // ─── Activity Events ─────────────────────────────────────
    // Written by Cloud Functions (admin SDK) only.
    // Publicly readable for the homepage live feed.
    match /activityEvents/{eventId} {
      allow read: if true;
      allow create, update, delete: if false;
    }

    // ─── Notifications ───────────────────────────────────────
    // Written by Cloud Functions (admin SDK) only.
    // Recipients can read and mark as read.
    match /notifications/{notificationId} {
      allow read: if isAuthenticated()
                  && request.auth.uid == resource.data.recipientId;
      // Only the recipient can update (to mark read=true)
      allow update: if isAuthenticated()
                    && request.auth.uid == resource.data.recipientId
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["read"]);
      allow create, delete: if false;
    }

    // ─── Messages ────────────────────────────────────────────
    match /messages/{conversationId} {
      allow read: if isAuthenticated()
                  && (resource == null
                      || request.auth.uid in resource.data.participants);
      allow create: if isAuthenticated()
                    && request.auth.uid in request.resource.data.participants
                    && request.resource.data.participants.size() >= 2
                    && request.resource.data.participants.size() <= 10;
      allow update: if isAuthenticated()
                    && request.auth.uid in resource.data.participants;
      allow delete: if false;

      // Subcollection: message entries
      match /entries/{entryId} {
        allow read: if isAuthenticated()
                    && request.auth.uid in get(/databases/$(database)/documents/messages/$(conversationId)).data.participants;
        allow create: if isAuthenticated()
                      && request.auth.uid in get(/databases/$(database)/documents/messages/$(conversationId)).data.participants
                      && request.resource.data.senderId == request.auth.uid;
        allow update, delete: if false;
      }
    }

    // ─── Comments ────────────────────────────────────────────
    match /comments/{commentId} {
      // Anyone can read comments (public)
      allow read: if true;
      // Authenticated users can create their own comments
      allow create: if isAuthenticated()
                    && request.resource.data.userId == request.auth.uid
                    && request.resource.data.content.size() >= 1
                    && request.resource.data.content.size() <= 1000;
      // Only the comment owner can delete
      allow delete: if isAuthenticated()
                    && request.auth.uid == resource.data.userId;
      // No updates (content is immutable; like counts managed server-side)
      allow update: if false;
    }

    // ─── Presence ────────────────────────────────────────────
    match /presence/{userId} {
      // Any authenticated user can read presence (for messaging/profile UI)
      allow read: if isAuthenticated();
      // Users can only write their own presence document
      allow write: if isOwner(userId);
    }

    // ─── Live Streams ─────────────────────────────────────────
    match /streams/{streamId} {
      // Anyone can read stream metadata (for viewer page & Live Now row)
      allow read: if true;
      // Only creators can start a stream (status set server-side)
      allow create: if isCreator()
                    && request.resource.data.creatorId == request.auth.uid;
      // Allow update only to owner (viewer count is updated server-side)
      allow update: if isOwner(resource.data.creatorId);
      allow delete: if false;

      // Subcollection: live chat messages
      match /chat/{messageId} {
        // Anyone can read chat (including anonymous viewers)
        allow read: if true;
        // Authenticated users can post chat messages
        allow create: if isAuthenticated()
                      && request.resource.data.userId == request.auth.uid
                      && request.resource.data.content.size() >= 1
                      && request.resource.data.content.size() <= 500;
        allow update, delete: if false;
      }

      // Subcollection: viewer presence (heartbeats)
      match /viewers/{userId} {
        // Authenticated users can read viewer presence (for count display)
        allow read: if isAuthenticated();
        // Viewers write their own presence only
        allow create, update: if isOwner(userId);
        allow delete: if false;
      }

      // Subcollection: private credentials (streamKey, ingestUrl)
      // Only the owning creator can read — never publicly accessible
      match /private/{doc} {
        allow read: if isAuthenticated()
                    && request.auth.uid == get(/databases/$(database)/documents/streams/$(streamId)).data.creatorId;
        allow create, update, delete: if false;
      }
    }
  }
}
