rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // ─── User avatars ──────────────────────────────────
    match /users/{uid}/avatar/{fileName} {
      // Public read
      allow read: if true;
      // Only the user can upload their own avatar
      allow write: if request.auth != null
                   && request.auth.uid == uid
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/(jpeg|png|webp)');
    }

    // ─── Project images ────────────────────────────────
    // Uploader must set customMetadata.creatorId matching their UID
    match /projects/{projectId}/images/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.resource.metadata.creatorId == request.auth.uid
                   && request.resource.size < 10 * 1024 * 1024
                   && request.resource.contentType.matches('image/(jpeg|png|webp)');
    }

    // ─── Product images ────────────────────────────────
    match /projects/{projectId}/products/{productId}/images/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.resource.metadata.creatorId == request.auth.uid
                   && request.resource.size < 10 * 1024 * 1024
                   && request.resource.contentType.matches('image/(jpeg|png|webp)');
    }

    // ─── Product images (standalone — no project) ────────
    match /products/{productId}/images/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.resource.metadata.creatorId == request.auth.uid
                   && request.resource.size < 10 * 1024 * 1024
                   && request.resource.contentType.matches('image/(jpeg|png|webp)');
    }

    // ─── Product downloads (standalone — no project) ────
    match /products/{productId}/downloads/{fileName} {
      allow read: if false;
      allow write: if request.auth != null
                   && request.resource.metadata.creatorId == request.auth.uid
                   && request.resource.size < 100 * 1024 * 1024;
    }

    // ─── Digital downloads (SECURED) ───────────────────
    // No direct client read — access via signed URLs from Cloud Functions
    match /projects/{projectId}/products/{productId}/downloads/{fileName} {
      allow read: if false;
      allow write: if request.auth != null
                   && request.resource.metadata.creatorId == request.auth.uid
                   && request.resource.size < 100 * 1024 * 1024;
    }

    // ─── Project videos ────────────────────────────────
    match /projects/{projectId}/videos/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.resource.metadata.creatorId == request.auth.uid
                   && request.resource.size < 200 * 1024 * 1024
                   && request.resource.contentType.matches('video/(mp4|webm|quicktime)');
    }

    // ─── Product videos (project-linked) ───────────────
    match /projects/{projectId}/products/{productId}/videos/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.resource.metadata.creatorId == request.auth.uid
                   && request.resource.size < 200 * 1024 * 1024
                   && request.resource.contentType.matches('video/(mp4|webm|quicktime)');
    }

    // ─── Product videos (standalone — no project) ──────
    match /products/{productId}/videos/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.resource.metadata.creatorId == request.auth.uid
                   && request.resource.size < 200 * 1024 * 1024
                   && request.resource.contentType.matches('video/(mp4|webm|quicktime)');
    }

    // ─── Video thumbnails (written by Cloud Functions) ─
    // Public read; client writes blocked — admin SDK bypasses rules
    match /thumbnails/projects/{projectId}/{fileName} {
      allow read: if true;
      allow write: if false;
    }

    match /thumbnails/products/{productId}/{fileName} {
      allow read: if true;
      allow write: if false;
    }
  }
}
