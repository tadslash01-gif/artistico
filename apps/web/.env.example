# Firebase Client Config (public — safe to commit in .env.local, NOT in repo)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Stripe (public key only on client)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Google AdSense (leave blank to disable ads)
NEXT_PUBLIC_ADSENSE_PUB_ID=

# ─── Server-side only (Firebase Functions secrets) ───
# These go in Firebase Secret Manager, NOT in .env files:
# STRIPE_SECRET_KEY
# STRIPE_WEBHOOK_SECRET
